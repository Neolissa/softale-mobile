{
  "name": "softale-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android:build": "expo run:android",
    "android:release": "eas build -p android --profile production",
    "android:rustore": "eas build -p android --profile rustore",
    "android:rustore:local": "eas build -p android --profile rustore --local",
    "android:dev": "expo start --dev-client",
    "backend:start": "npm --prefix ./backend run start",
    "backend:dev": "npm --prefix ./backend run dev",
    "preview:android": "bash ./live-preview.sh",
    "preview:android:dev": "bash ./live-preview.sh --dev",
    "go": "bash ./live-preview.sh",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.33",
    "expo-av": "^16.0.8",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
